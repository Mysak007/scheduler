{
    "name": "app/scheduler",
    "description": "Simple scheduler interfaces with Laravel implementation and custom mutex.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "dragonmantank/cron-expression": "^3.3",
        "illuminate/console": "^11.0",
        "illuminate/contracts": "^11.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    }
}
